# Blueprint HR — Local Development env vars
#
# Copy this file to `.env.local` and fill in the marked values.
# `.env.local` is gitignored; never commit real secrets.
#
# What each cell means:
#   REQUIRED  — the app crashes / a route 500s without this.
#   OPTIONAL  — feature degrades gracefully when missing.
#   DEV-ONLY  — used only for local dev / CI. Do not set in production.
#
# Boot order: set the REQUIRED block, then run `npm run dev`.

# ─── App / framework ───────────────────────────────────────────────────────
# Public URL the browser reaches the app at. Used in tokenized digest links.
NEXT_PUBLIC_APP_URL=http://localhost:3000              # REQUIRED (any valid URL works locally)

# ─── Supabase (database + auth + storage) ─────────────────────────────────
# Get all three from Supabase project Settings → API.
# https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=                              # REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=                         # REQUIRED — public anon key
SUPABASE_SERVICE_ROLE_KEY=                             # REQUIRED — server-side only, NEVER expose to client

# ─── Anthropic / Claude ────────────────────────────────────────────────────
# Powers extract-report.ts (operations intake), the AI agent, image OCR.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=                                     # REQUIRED for any AI feature (intake, agent, OCR)

# ─── Twilio (inbound WhatsApp) ─────────────────────────────────────────────
# Required for the production webhook. Local dev doesn't usually need these.
TWILIO_ACCOUNT_SID=                                    # OPTIONAL (REQUIRED for /api/webhooks/twilio/whatsapp)
TWILIO_AUTH_TOKEN=                                     # OPTIONAL — used to verify webhook signatures
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886             # OPTIONAL — sandbox sender; your real number in prod
TWILIO_SKIP_SIGNATURE_VERIFICATION=true                # DEV-ONLY — bypass sig check locally; MUST be false/unset in prod

# ─── Operations: cron + digests ────────────────────────────────────────────
CRON_SECRET=                                           # REQUIRED for cron jobs — generate via `openssl rand -hex 32`
OPERATIONS_DIGEST_SECRET=                              # REQUIRED for tokenized digest links — generate same way
OPERATIONS_CEO_EMAIL=                                  # OPTIONAL (REQUIRED to send daily digest)
OPERATIONS_CEO_WHATSAPP=                               # OPTIONAL (REQUIRED to send digest WhatsApp)

# ─── Bulk-import knobs ─────────────────────────────────────────────────────
# Defaults are sensible; only override if you know why.
BULK_IMPORT_MAX_REPORTS=200                            # OPTIONAL — hard cap per batch
BULK_IMPORT_CONCURRENCY=10                             # OPTIONAL — Claude calls in parallel
BULK_IMPORT_DEDUP_WINDOW_HOURS=24                      # OPTIONAL — dedup lookback

# ─── Gmail (used by recruitment messaging) ────────────────────────────────
# Optional. Without these, the email-send path returns a clear error.
GMAIL_CLIENT_ID=                                       # OPTIONAL
GMAIL_CLIENT_SECRET=                                   # OPTIONAL
GMAIL_REFRESH_TOKEN=                                   # OPTIONAL
GMAIL_SENDER_EMAIL=                                    # OPTIONAL
NEXT_PUBLIC_GMAIL_CONFIGURED=false                     # OPTIONAL — set to "true" only when Gmail is wired

# ─── Tests / CI ────────────────────────────────────────────────────────────
# Used by jest + scripts/a1-migration-sweep.js. Only relevant if you run tests.
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test  # DEV-ONLY
